# Render Environment Variables Example
# These should be set in the Render dashboard for each service

# MinIO Credentials (Required)
# Set these in Render dashboard for MinIO, Loki, and Tempo services
MINIO_ROOT_USER=your-minio-username
MINIO_ROOT_PASSWORD=your-strong-password

# MinIO Buckets (Optional - have defaults)
MINIO_LOKI_BUCKET=loki
MINIO_TEMPO_BUCKET=tempo

# Service Endpoints (Auto-configured by Render)
# These are automatically set via render.yaml fromService references
# LOKI_ENDPOINT=http://loki:3100/loki/api/v1/push
# TEMPO_ENDPOINT=tempo:4317
# MINIO_ENDPOINT=minio:9000
