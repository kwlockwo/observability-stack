{
  "title": "Render Services",
  "uid": "render-services",
  "tags": ["render"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Prometheus",
        "pluginId": "prometheus",
        "current": {}
      },
      {
        "type": "query",
        "name": "service",
        "label": "Service",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(render_service_cpu_limit, service_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "CPU",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "description": "CPU usage as a percentage of the limit, calculated from cumulative CPU time.",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "100 * rate(render_service_cpu_time{service_name=~\"$service\"}[5m]) / on(service_name, service_id, service_instance_id) render_service_cpu_limit{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} ({{service_instance_id}})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Limit (cores)",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 2 }
      },
      "targets": [
        {
          "expr": "render_service_cpu_limit{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} ({{service_instance_id}})"
        }
      ]
    },
    {
      "type": "row",
      "title": "Memory",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "render_service_memory_usage{service_name=~\"$service\"}",
          "legendFormat": "usage {{service_name}} ({{service_instance_id}})"
        },
        {
          "expr": "render_service_memory_rss{service_name=~\"$service\"}",
          "legendFormat": "rss {{service_name}} ({{service_instance_id}})"
        },
        {
          "expr": "render_service_memory_cache{service_name=~\"$service\"}",
          "legendFormat": "cache {{service_name}} ({{service_instance_id}})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage %",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      },
      "targets": [
        {
          "expr": "100 * render_service_memory_usage{service_name=~\"$service\"} / on(service_name, service_id, service_instance_id) render_service_memory_limit{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} ({{service_instance_id}})"
        }
      ]
    },
    {
      "type": "row",
      "title": "Network",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Network Throughput",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "rate(render_service_network_transmit_bytes{service_name=~\"$service\"}[5m])",
          "legendFormat": "tx {{service_name}} ({{service_instance_id}})"
        },
        {
          "expr": "rate(render_service_network_receive_bytes{service_name=~\"$service\"}[5m])",
          "legendFormat": "rx {{service_name}} ({{service_instance_id}})"
        }
      ]
    },
    {
      "type": "row",
      "title": "HTTP Requests",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 0, "y": 25, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (service_name, status_code) (rate(render_service_http_requests_total{service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}} {{status_code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Latency",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "render_service_http_requests_latency{service_name=~\"$service\", quantile=\"0.99\"}",
          "legendFormat": "p99 {{service_name}}"
        },
        {
          "expr": "render_service_http_requests_latency{service_name=~\"$service\", quantile=\"0.95\"}",
          "legendFormat": "p95 {{service_name}}"
        },
        {
          "expr": "render_service_http_requests_latency{service_name=~\"$service\", quantile=\"0.50\"}",
          "legendFormat": "p50 {{service_name}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Disk",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Disk Usage",
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "render_service_disk_usage{service_name=~\"$service\"}",
          "legendFormat": "used {{service_name}}"
        },
        {
          "expr": "render_service_disk_capacity{service_name=~\"$service\"}",
          "legendFormat": "capacity {{service_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk I/O",
      "gridPos": { "x": 12, "y": 33, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "rate(render_service_disk_read_bytes{service_name=~\"$service\"}[5m])",
          "legendFormat": "read {{service_name}}"
        },
        {
          "expr": "rate(render_service_disk_write_bytes{service_name=~\"$service\"}[5m])",
          "legendFormat": "write {{service_name}}"
        }
      ]
    }
  ]
}
